rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global stats are publicly readable and updatable via atomic increments
    match /stats/global {
      allow read: if true;
      allow write: if true;
    }
    
    // Contributions are identified by a unique ID: {fingerprint}_{YYYY}_{MM}
    // We allow creation but strictly forbid updates to prevent double-counting or tampering
    match /contributions/{contributionId} {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/contributions/$(contributionId));
      allow update, delete: if false;
    }
    
    // Forum posts use a similar fingerprinting logic to limit daily spam
    match /forum_posts/{postId} {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/forum_posts/$(postId));
      allow update, delete: if false;
    }
  }
}